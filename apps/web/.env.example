# ============================================
# AICR Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
# Port the frontend server listens on (only used in Docker)
WEB_PORT=3000

# ============================================
# API Configuration
# ============================================
# URL of the backend API server
# This is used to make API requests from the frontend
#
# IMPORTANT: This is a BUILD-TIME variable (baked into the bundle)
# You must rebuild the Docker image to change this value
#
# For production: https://api.aicr.example.com
# For local dev: http://localhost:3000
VITE_API_URL=http://localhost:3000
