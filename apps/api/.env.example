# ============================================
# AICR Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
# Port the API server listens on
API_PORT=3000

# Frontend URL - used for CORS (which origins are allowed to make requests)
# Example: https://aicr.example.com or http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Owner user ID for experiments page (admin access)
# Get this from the database after creating your account
OWNER_USER_ID=your-owner-user-id

# ============================================
# Database (Turso)
# ============================================
# Get these from https://turso.tech
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=your-turso-token

# ============================================
# Redis (Upstash)
# ============================================
# Get these from https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# Reap API (AI video clipping provider)
# ============================================
# Get your API key from https://app.reap.video (Profile > Settings > API Keys)
REAP_API_KEY=your-reap-api-key

# ============================================
# Authentication (Better Auth)
# ============================================
# Generate a random 32+ character secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-random-32-char-secret-here

# Public URL of this API server
# For production: https://api.aicr.example.com
# For local dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (for social sign-in)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Reka Vision API
REKA_API_KEY=your-reka-api-key-here

# Vizard AI API (optional — new provider, register when you have a key)
# Get your key from https://docs.vizard.ai/docs/quickstart
VIZARD_API_KEY=

# Ssemble AI Clipping API (optional — new provider, register when you have a key)
# Get your key from https://www.ssemble.com/docs
SSEMBLE_API_KEY=
