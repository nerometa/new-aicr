# ============================================
# AICR Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
# Port the API server listens on
API_PORT=3000

# Frontend URL - used for CORS (which origins are allowed to make requests)
# Example: https://aicr.example.com or http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ============================================
# Database (Turso)
# ============================================
# Get these from https://turso.tech
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=your-turso-token

# ============================================
# Redis (Upstash)
# ============================================
# Get these from https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# Klap API (Video-to-shorts service)
# ============================================
# Get your API key from https://klap.app
KLAP_API_KEY=your-klap-api-key
KLAP_API_URL=https://api.klap.video/v2

# Optional: Customize clip generation
# KLAP_MAX_DURATION=30
# KLAP_MAX_CLIP_COUNT=3

# ============================================
# Authentication (Better Auth)
# ============================================
# Generate a random 32+ character secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-random-32-char-secret-here

# Public URL of this API server
# For production: https://api.aicr.example.com
# For local dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
