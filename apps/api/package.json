{
  "name": "api",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "test": "vitest",
    "db:generate": "drizzle-kit generate --dialect sqlite",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@libsql/client": "^0.17.0",
    "@upstash/redis": "^1.36.2",
    "better-auth": "^1.4.18",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "zod": "^4.3.6"
  }
}
